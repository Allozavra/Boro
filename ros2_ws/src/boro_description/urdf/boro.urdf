<?xml version="1.0"?>
<robot name="boro">

  <link name="base">
    <visual>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.3" radius="0.01"/>
      </geometry>
    </visual>
  </link>

  <!-- Было вращение вокруг Y, делаем через вращение вокруг локальной Z -->
  <joint name="joint_phi" type="revolute">
    <parent link="base"/>
    <child link="link1"/>
    <origin xyz="0 0 0.3" rpy="-1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.79" upper="0.79" effort="0" velocity="0"/>
  </joint>

  <link name="link1">
    <inertial>
      <!-- Компенсация поворота frame link1 -->
      <origin xyz="0 -0.1 0" rpy="1.57079632679 0 0"/>
      <mass value="0.1703"/>
      <inertia
        ixx="5.7184e-04" iyy="8.5137e-06" izz="5.7184e-04"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <!-- Компенсация поворота frame link1 -->
      <origin xyz="0 -0.1 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.01"/>
      </geometry>
    </visual>
  </link>

  <!-- Было движение вдоль Z, сохраняем его визуально тем же,
       но компенсируем поворот link1 -->
  <joint name="joint_h" type="prismatic">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 -0.1 0" rpy="1.57079632679 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.1" upper="0.1" effort="0" velocity="0"/>
  </joint>

  <link name="link2">
    <inertial>
      <origin xyz="0.4 0 0" rpy="0 1.57079632679 0"/>
      <mass value="0.3405"/>
      <inertia
        ixx="0.0045" iyy="1.7027e-05" izz="0.0045"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0.4 0 0" rpy="0 1.57079632679 0"/>
      <geometry>
        <cylinder length="0.8" radius="0.01"/>
      </geometry>
    </visual>
  </link>

  <!-- Было движение вдоль X, делаем через локальную Z -->
  <joint name="joint_l" type="prismatic">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.4 0 0" rpy="0 1.57079632679 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.4" upper="0.4" effort="0" velocity="0"/>
  </joint>

  <link name="link3">
    <inertial>
      <!-- Компенсация поворота frame link3 -->
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <mass value="0.5108"/>
      <inertia
        ixx="0.0153" iyy="2.5541e-05" izz="0.0153"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <!-- Компенсация поворота frame link3 -->
      <origin xyz="0.05 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.6" radius="0.01"/>
      </geometry>
    </visual>
  </link>

  <link name="bow_contact_frame"/>

  <!-- Если нужно сохранить старую ориентацию contact frame -->
  <joint name="bow_contact_frame_joint" type="fixed">
    <parent link="link3"/>
    <child link="bow_contact_frame"/>
    <origin xyz="0.05 0 0" rpy="3.141592653589793 -1.57079632679 0"/>
  </joint>

</robot>