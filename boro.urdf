<?xml version="1.0"?>
<robot name="boro">

<link name="base">
  <visual>
    <origin xyz="0 0 0.15"/>
    <geometry>
      <cylinder length="0.3" radius="0.01"/>
    </geometry>
  </visual>
</link>

<joint name="joint_phi" type="revolute">
  <parent link="base"/>
  <child link="link1"/>
  <origin xyz="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-0.79" upper="0.79"/>
</joint>

<link name="link1">
  <inertial>
    <!-- <origin xyz="0 0 0.1"/> -->
    <!-- <mass value="0.5"/> -->
    <!-- <inertia  -->
      <!-- ixx="0.001" iyy="0.002" izz="0.001" -->
      <!-- ixy="0" ixz="0" iyz="0"/> -->
  </inertial>
  <visual>
    <origin xyz="0 0 0.1"/>
    <geometry>
      <cylinder length="0.2" radius="0.01"/>
    </geometry>
  </visual>
</link>

<joint name="joint_h" type="prismatic">
  <parent link="link1"/>
  <child link="link2"/>
  <origin xyz="0 0 0.1" rpy="0 0 0"/>
  <axis xyz="0 0 1"/>
  <!-- <limit lower="0" upper="0.1"/> -->
</joint>
// !!!!!!!!!!!!!!!!!!!
<link name="link2">
  <inertial>
    <origin xyz="0.35 0 0"/>
    <!-- <mass value="0.3"/>
    <inertia 
      ixx="0.0005" iyy="0.0005" izz="0.0002"
      ixy="0" ixz="0" iyz="0"/> -->
  </inertial>
  <visual>
    <origin xyz="0.35 0 0"/>
    <geometry>
      <cylinder length="0.2" radius="0.01"/>
    </geometry>
  </visual>
</link>

<joint name="joint_l" type="prismatic">
  <parent link="link2"/>
  <child link="link3"/>
  <origin xyz="0 0 0" rpy="0 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="0" upper="0.3"/>
</joint>

<link name="link3">
  <inertial>
    <origin xyz="0.15 0 0"/>
    <mass value="0.2"/>
    <inertia 
      ixx="0.0003" iyy="0.0001" izz="0.0003"
      ixy="0" ixz="0" iyz="0"/>
  </inertial>
</link>

</robot>